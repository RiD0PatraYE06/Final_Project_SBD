# Manajemen Perlengkapan OPR ARA

```javascript
// ======================================================
// DATABASE
// ======================================================

use manajemen_perlengkapan_opr_nosql



// ======================================================
// COLLECTION : equipment_logs
// ======================================================

db.createCollection("equipment_logs")

db.equipment_logs.insertMany([
{
    id_barang: "BRG126",
    nama_barang: "Speaker JBL",
    aktivitas: "dipinjam",
    oleh: {
        tipe: "Divisi",
        nama: "Divisi Acara"
    },
    lokasi: {
        gedung: "TW 2",
        ruangan: "Hall A"
    },
    kondisi: "baik",
    timestamp: new Date("2026-06-01T08:00:00Z")
},

{
    id_barang: "BRG127",
    nama_barang: "Lighting LED",
    aktivitas: "dipindahkan",
    oleh: {
        tipe: "Anggota OPR",
        nama: "Rayhan"
    },
    lokasi: {
        gedung: "TW 2",
        ruangan: "Gudang"
    },
    kondisi: "baik",
    timestamp: new Date("2026-06-01T09:30:00Z")
},

{
    id_barang: "BRG128",
    nama_barang: "Karpet Event",
    aktivitas: "dikembalikan",
    oleh: {
        tipe: "Divisi",
        nama: "Divisi Media"
    },
    lokasi: {
        gedung: "TW 2",
        ruangan: "Storage"
    },
    kondisi: "sedikit kotor",
    timestamp: new Date("2026-06-02T10:15:00Z")
}
])



// ======================================================
// COLLECTION : maintenance_logs
// ======================================================

db.createCollection("maintenance_logs")

db.maintenance_logs.insertMany([
{
    id_barang: "BRG126",
    nama_barang: "Speaker JBL",
    jenis_maintenance: "Perbaikan",
    deskripsi: "Kabel speaker rusak",
    status: "selesai",
    vendor: {
        id_vendor: "V001",
        nama_vendor: "SoundPro"
    },
    biaya: 250000,
    tanggal: new Date("2026-06-03")
},

{
    id_barang: "BRG127",
    nama_barang: "Lighting LED",
    jenis_maintenance: "Pembersihan",
    deskripsi: "Debu pada lampu",
    status: "proses",
    vendor: {
        id_vendor: "V002",
        nama_vendor: "LightTech"
    },
    biaya: 100000,
    tanggal: new Date("2026-06-04")
}
])



// ======================================================
// COLLECTION : coordination_logs
// ======================================================

db.createCollection("coordination_logs")

db.coordination_logs.insertMany([
{
    divisi: "OPR",
    anggota: "Rayhan",
    pesan: "Speaker sudah dipindahkan ke Hall A",
    prioritas: "high",
    status: "done",
    timestamp: new Date("2026-06-05T13:20:00Z")
},

{
    divisi: "Media",
    anggota: "Fikri",
    pesan: "Butuh tambahan lighting untuk acara",
    prioritas: "medium",
    status: "pending",
    timestamp: new Date("2026-06-05T15:45:00Z")
},

{
    divisi: "Acara",
    anggota: "Nanda",
    pesan: "Karpet perlu dibersihkan sebelum dipakai",
    prioritas: "low",
    status: "done",
    timestamp: new Date("2026-06-06T09:00:00Z")
}
])



// ======================================================
// INDEXING
// ======================================================

// Equipment Logs
db.equipment_logs.createIndex({ id_barang: 1 })
db.equipment_logs.createIndex({ aktivitas: 1 })
db.equipment_logs.createIndex({ timestamp: -1 })

// Maintenance Logs
db.maintenance_logs.createIndex({ status: 1 })
db.maintenance_logs.createIndex({ tanggal: -1 })

// Coordination Logs
db.coordination_logs.createIndex({ prioritas: 1 })
db.coordination_logs.createIndex({ timestamp: -1 })



// ======================================================
// QUERY DASAR
// ======================================================

// Menampilkan semua equipment logs
db.equipment_logs.find()


// Menampilkan log barang tertentu
db.equipment_logs.find({
    id_barang: "BRG126"
})


// Menampilkan maintenance yang masih proses
db.maintenance_logs.find({
    status: "proses"
})


// Menampilkan coordination logs prioritas tinggi
db.coordination_logs.find({
    prioritas: "high"
})



// ======================================================
// SORTING
// ======================================================

// Log terbaru
db.equipment_logs.find()
.sort({ timestamp: -1 })


// Maintenance terbaru
db.maintenance_logs.find()
.sort({ tanggal: -1 })



// ======================================================
// UPDATE
// ======================================================

// Mengubah status maintenance
db.maintenance_logs.updateOne(
{
    id_barang: "BRG127"
},
{
    $set: {
        status: "selesai"
    }
}
)



// ======================================================
// DELETE
// ======================================================

// Menghapus coordination log tertentu
db.coordination_logs.deleteOne({
    anggota: "Nanda"
})



// ======================================================
// AGGREGATION
// ======================================================

// Menghitung jumlah aktivitas barang
db.equipment_logs.aggregate([
{
    $group: {
        _id: "$aktivitas",
        total: { $sum: 1 }
    }
}
])



// Menghitung total biaya maintenance
db.maintenance_logs.aggregate([
{
    $group: {
        _id: null,
        total_biaya: { $sum: "$biaya" }
    }
}
])



// Menampilkan jumlah koordinasi berdasarkan prioritas
db.coordination_logs.aggregate([
{
    $group: {
        _id: "$prioritas",
        jumlah: { $sum: 1 }
    }
}
])



// ======================================================
// ADVANCED QUERY
// ======================================================

// Menampilkan log barang pada bulan Juni 2026
db.equipment_logs.find({
    timestamp: {
        $gte: new Date("2026-06-01"),
        $lt: new Date("2026-07-01")
    }
})



// Menampilkan maintenance dengan biaya di atas 150000
db.maintenance_logs.find({
    biaya: {
        $gt: 150000
    }
})



// ======================================================
// TEXT SEARCH INDEX
// ======================================================

db.coordination_logs.createIndex({
    pesan: "text"
})



// Search pesan koordinasi
db.coordination_logs.find({
    $text: {
        $search: "lighting"
    }
})



// ======================================================
// VALIDASI SEDERHANA
// ======================================================

// Insert data baru equipment log
db.equipment_logs.insertOne({
    id_barang: "BRG129",
    nama_barang: "Mic Wireless",
    aktivitas: "dipinjam",
    oleh: {
        tipe: "Divisi",
        nama: "Divisi Acara"
    },
    lokasi: {
        gedung: "TW 2",
        ruangan: "Main Hall"
    },
    kondisi: "baik",
    timestamp: new Date()
})



// ======================================================
// MENAMPILKAN SEMUA COLLECTION
// ======================================================

show collections
```
